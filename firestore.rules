rules_version = '2';

// ColorMagic Kids — Firestore security rules.
//
// The app is backend-authoritative: ALL writes to credits and sketches go
// through Cloud Functions (Admin SDK, which bypasses these rules). Clients
// get READ access to their own data only, and NO write access anywhere —
// so a tampered client can never mint credits or forge a sketch.
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} — a parent/child's plan + credit ledger.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // server-only (Functions)
    }

    // sketches/{sketchId} — generated coloring pages.
    match /sketches/{sketchId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow write: if false; // server-only (Functions)
    }

    // processedPurchases — billing idempotency ledger. Server-only, fully
    // private (no client ever needs to read it).
    match /processedPurchases/{token} {
      allow read, write: if false;
    }

    // processedAdRewards — AdMob SSV idempotency ledger (one doc per
    // transaction_id). Server-only, fully private.
    match /processedAdRewards/{transactionId} {
      allow read, write: if false;
    }

    // feedback — parent-submitted support messages. Written only by the
    // submitFeedback Cloud Function (Admin SDK); never readable/writable by
    // clients.
    match /feedback/{id} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
