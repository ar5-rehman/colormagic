{
  "name": "colormagic-functions",
  "description": "ColorMagic Kids — Firebase backend (sketch generation, credits, billing).",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest --testPathPattern='src/.*\\.test\\.ts$'"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "firebase-admin/firestore": "<rootDir>/src/__mocks__/firebase-admin-firestore.ts"
    }
  },
  "dependencies": {
    "firebase-admin": "^13.0.1",
    "firebase-functions": "^6.1.1",
    "googleapis": "^144.0.0",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4"
  }
}
